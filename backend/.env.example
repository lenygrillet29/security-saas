# Port (Railway le définit automatiquement)
PORT=3001

# Origines CORS autorisées (séparées par virgule)
CORS_ORIGIN=https://VOTRE_APP.vercel.app

# URL publique du frontend (pour les liens dans les emails)
APP_URL=https://VOTRE_APP.vercel.app

# ── Notifications push (Web Push / PWA) ──────────────────────────────────────
# Générer avec : node -e "require('web-push').generateVAPIDKeys()"
# Ces deux clés doivent être identiques sur Railway et Vercel
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
